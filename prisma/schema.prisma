generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Clientes ─────────────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  cpf       String?  @unique
  facePhoto       String?  // base64 JPEG para Control iD
  controlidUserId Int?     // ID do usuário no iDFace
  asaasCustomerId String?  // ID do cliente no ASAAS
  asaasCardToken  String?  // Token do cartão salvo no ASAAS
  createdAt       DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings         Booking[]
  subscriptions    Subscription[]
  consumableSales  ConsumableSale[]

  @@map("clients")
}

// ── Agendamentos ─────────────────────────────────────────────────
model Booking {
  id               String        @id @default(cuid())
  clientId         String
  client           Client        @relation(fields: [clientId], references: [id])

  startAt          DateTime
  endAt            DateTime
  totalAmount      Float
  status           BookingStatus @default(PENDING)

  // Pagamento ASAAS
  asaasChargeId    String?       @unique
  asaasPaymentUrl  String?
  paidAt           DateTime?

  // Voucher aplicado
  voucherId        String?
  voucher          Voucher?      @relation(fields: [voucherId], references: [id])
  discountAmount   Float?        @default(0)

  // Assinatura (planos multi-período)
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])

  // Control iD
  controlIdUserId  String?
  accessGrantedAt  DateTime?
  accessRevokedAt  DateTime?

  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  accessLogs       AccessLog[]

  @@map("bookings")
}

enum BookingStatus {
  PENDING
  PAID
  ACTIVE
  COMPLETED
  CANCELLED
  REFUNDED
}

// ── Vouchers ─────────────────────────────────────────────────────
model Voucher {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String?
  discountType  DiscountType
  discountValue Float
  maxUses       Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())

  bookings      Booking[]

  @@map("vouchers")
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ── Assinaturas (planos multi-período) ───────────────────────────
model Subscription {
  id           String             @id @default(cuid())
  clientId     String
  client       Client             @relation(fields: [clientId], references: [id])
  planKey      String             // HUB_FIVE | HUB_TEN | HUB_PARTNER
  totalCredits Int
  usedCredits  Int                @default(0)
  status       SubscriptionStatus @default(ACTIVE)
  expiresAt    DateTime
  totalAmount  Float
  asaasChargeId String?           @unique
  token        String             @unique @default(cuid()) // magic link
  frozenReason String?            // motivo do congelamento
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  bookings     Booking[]

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  FROZEN
}

// ── Log de Acessos ────────────────────────────────────────────────
model AccessLog {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  event     String
  details   String?
  createdAt DateTime @default(now())

  @@map("access_logs")
}

// ── Leads (dados de step 2 não convertidos) ───────────────────────
model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  cpf       String?
  planKey   String
  createdAt DateTime @default(now())

  @@map("leads")
}

// ── Insumos (frigobar, café, etc.) ───────────────────────────────
model Consumable {
  id             String   @id @default(cuid())
  code           String?  // código do produto (P001, P002...)
  name           String
  unit           String?  // LATA, GARRAFA, SACHÊ, UN...
  photo          String?  // base64 ou URL
  price          Float    // preço de venda
  costPrice      Float?   // preço de custo (para margem/ROI)
  description    String?
  active         Boolean  @default(true)
  stockDeposito  Int      @default(0)  // estoque no depósito/reserva
  stockFrigobar  Int      @default(0)  // estoque no frigobar (exposto)
  minStock       Int      @default(2)  // mínimo no frigobar para alerta
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sales          ConsumableSale[]

  @@map("consumables")
}

// ── Vendas de insumos ─────────────────────────────────────────────
model ConsumableSale {
  id           String      @id @default(cuid())
  consumableId String
  consumable   Consumable  @relation(fields: [consumableId], references: [id])
  qty          Int
  unitPrice    Float
  totalPrice   Float
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id])
  bookingId    String?     // preenchido quando vem de finalizar sessão
  source       String      // "session" | "manual"
  createdAt    DateTime    @default(now())

  @@map("consumable_sales")
}

// ── Configurações do sistema ──────────────────────────────────────
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── Admin ─────────────────────────────────────────────────────────
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  @@map("admins")
}
